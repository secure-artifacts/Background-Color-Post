{
  "manifest_version": 3,
  "name": "__MSG_extName__ debug",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "author": "Raz1ner",
  "version": "1.0.10",
  "action": {
    "default_icon": "img/icon.png"
  },
  "icons": {
    "128": "img/icon.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/extID.js"],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "matches": ["<all_urls>"]
  },
  "web_accessible_resources": [{
    "resources": ["js/inject.js"],
    "matches": ["<all_urls>"]
  }],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.facebook.com/*",
    "https://raz1ner.com/Extension/Background-Color-Post/*"
  ]
}
